# dependências / build
node_modules/
dist/
*.tsbuildinfo

# ambiente
.env
.env.local

# dados: fontes brutas e derivados ficam fora do Git (JSONL canônico é versionado)
# diretórios são re-incluídos para o git conseguir enxergar os LICENSE.txt
data/sources/**
!data/sources/.gitkeep
!data/sources/*/
!data/sources/**/LICENSE.txt
!data/sources/manifest.json
data/derived/**
!data/derived/.gitkeep

# modelos / caches
models/
__pycache__/
*.pyc
.venv/

# config local
.claude/settings.local.json

# logs
*.log
