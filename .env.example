DATABASE_URL=postgres://bereia:bereia@localhost:5432/bereia
EMBEDDER_URL=http://localhost:8000
# Raiz dos dados brutos (sources/) — local, fora do Git
DATA_DIR=./data
# JSONL canônico (fonte de verdade) — vive no repo zoelner/bereia-data (ADR-009).
# Aponte para o subdiretório canonical/ de um clone dele; sem esta variável, os
# CLIs usam DATA_DIR/canonical (build local, gitignorado).
# CANONICAL_DIR=../bereia-data/canonical
# Destino do build:canonical (o conteúdo é APAGADO e regravado a cada build).
# Para publicar dado oficial, aponte para o canonical/ do clone do bereia-data.
# OUT_DIR=../bereia-data/canonical
